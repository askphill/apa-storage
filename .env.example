# Cloudflare R2 credentials
# Find these at: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=apa-storage

# Public URL for the bucket (set up via R2 > Bucket > Settings > Public Access)
# Either a custom domain or the r2.dev subdomain
R2_PUBLIC_URL=https://your-bucket.your-account-id.r2.dev
